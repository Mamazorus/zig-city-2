{
  "name": "raw-launcher",
  "version": "0.1.16-beta",
  "description": "Launcher Minecraft custom Zig City 2",
  "author": "Maël Auzenet",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win",
    "publish:win": "electron-vite build && electron-builder --win --publish always",
    "build:mac": "electron-vite build && electron-builder --mac",
    "publish:mac": "electron-vite build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.4.16",
    "electron-updater": "^6.8.9",
    "minecraft-launcher-core": "^3.17.1",
    "msmc": "^3.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "skinview3d": "^3.4.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.rawstudio.launcher",
    "productName": "Zig City 2",
    "copyright": "Copyright © 2026 Maël Auzenet",
    "afterPack": "build/afterPack.js",
    "files": [
      "out/**",
      "modpack.json",
      "assets/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo_zig_city.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "icon": "assets/logo_zig_city.png",
      "category": "public.app-category.games",
      "identity": null
    },
    "nsis": {
      "oneClick": true
    },
    "publish": {
      "provider": "github",
      "owner": "Mamazorus",
      "repo": "zig-city-2",
      "releaseType": "prerelease"
    }
  }
}
